function reSetAddr(frm, sido, sigun, dong){

	var f = document.forms[frm];

	if( sido == undefined ) sido = "";
	if( sigun == undefined ) sigun = "";
	if( dong == undefined ) dong = "";

	idx_sido = -1;
	f.item3.length = 1;
	f.item3[0].text = "시/도";
	f.item3[0].value = "";
	for( i = 0 ; i < ADDR_SIDO.length; i++ ){
		f.item3.length += 1;
		f.item3[i+1].text = ADDR_SIDO[i];
		f.item3[i+1].value = ADDR_SIDO[i];

		if( sido == ADDR_SIDO[i] ){
			f.item3.selectedIndex = i+1;
			idx_sido = i;
		}
	}

	idx_sigun = -1;
	f.item4.length = 1;
	f.item4[0].text = "시/군/구";
	f.item4[0].value = "";
	if( idx_sido != -1 ){
		for( i = 0 ; i < ADDR_SIGUN[idx_sido].length; i++ ){
			f.item4.length += 1;
			f.item4[i+1].text = ADDR_SIGUN[idx_sido][i];
			f.item4[i+1].value = ADDR_SIGUN[idx_sido][i];

			if( sigun == ADDR_SIGUN[idx_sido][i] ){
				f.item4.selectedIndex = i+1;
				idx_sigun = i;
			}
		}
	}

}

