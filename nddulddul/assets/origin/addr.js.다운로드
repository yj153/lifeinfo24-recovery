	const item4 = $('#' + id +' select[name="item4"]');
	const item5 = $('#' + id +' select[name="item5"]');
	const item6 = $('#' + id +' select[name="item6"]');

	if($.trim(item2.val()) == '' || item2.val() == null){
		alert('이사일자를 입력하세요.');
		item2.focus();
		return false;
	}

	if($.trim(item3.val()) == ''){
		alert('출발지주소를 선택하세요.');
